@page
@model ManwhaWebsite.Areas.Identity.Pages.Account.ConfirmEmailModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(Model.Success ? "Welcome to ManhwaVault" : "Verification Failed") — ManhwaVault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #0d0d12;
            --surface: #1e1e2e;
            --border: rgba(255,255,255,0.06);
            --accent: #e8445a;
            --text: #eaeaf0;
            --text-muted: #7878a0;
            --radius-sm: 8px;
            --radius-md: 14px;
            --font-display: 'Bebas Neue', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --nav-h: 68px;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-body);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        a { text-decoration: none; color: inherit; }

        nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 100;
            height: var(--nav-h);
            background: rgba(13,13,18,0.9);
            backdrop-filter: blur(20px) saturate(180%);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 24px;
        }

        .nav-logo {
            font-family: var(--font-display);
            font-size: 26px;
            letter-spacing: 2px;
            color: #fff;
        }

        .nav-logo span { color: var(--accent); }

        .page-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: calc(var(--nav-h) + 40px) 16px 60px;
        }

        .card {
            width: 100%;
            max-width: 480px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 52px 40px;
            text-align: center;
        }

        .icon {
            font-size: 52px;
            margin-bottom: 22px;
            display: block;
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 36px;
            letter-spacing: 2px;
            margin-bottom: 14px;
            line-height: 1.1;
        }

        .card-title span { color: var(--accent); }

        .card-body {
            font-size: 15px;
            color: var(--text-muted);
            line-height: 1.65;
            margin-bottom: 10px;
        }

        .redirect-note {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 28px;
            padding-top: 22px;
            border-top: 1px solid var(--border);
        }

        .redirect-note a {
            color: var(--accent);
            font-weight: 500;
        }

        .redirect-note a:hover { text-decoration: underline; }

        .countdown {
            font-weight: 600;
            color: var(--text);
        }

        /* progress bar */
        .progress-bar-wrap {
            height: 3px;
            background: var(--border);
            border-radius: 2px;
            margin-top: 14px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: var(--accent);
            border-radius: 2px;
            width: 100%;
            transform-origin: left;
            animation: drain 3s linear forwards;
        }

        @@keyframes drain {
            from { transform: scaleX(1); }
            to   { transform: scaleX(0); }
        }

        /* error state */
        .card.error .card-title span { color: var(--text-muted); }
    </style>
</head>
<body>
    <nav>
        <a href="/" class="nav-logo">Manhwa<span>Vault</span></a>
    </nav>

    <div class="page-wrap">
        @if (Model.Success)
        {
            <div class="card">
                <span class="icon">🎉</span>
                <div class="card-title">Welcome to <span>ManhwaVault</span></div>
                <p class="card-body">
                    Thank you for signing up — your email has been verified and you're now signed in.
                </p>
                <p class="card-body">
                    Start exploring trending manhwa, track your reading list, and discover your next obsession.
                </p>
                <div class="redirect-note">
                    Redirecting to the home page in <span class="countdown" id="count">3</span>s…
                    or <a href="/">go now</a>
                    <div class="progress-bar-wrap">
                        <div class="progress-bar"></div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card error">
                <span class="icon">⚠️</span>
                <div class="card-title">Link <span>Expired</span></div>
                <p class="card-body">
                    This verification link is invalid or has already been used.
                </p>
                <div class="redirect-note">
                    <a href="/Identity/Account/Register">Register again</a> or <a href="/Identity/Account/Login">sign in</a> if your account is already active.
                </div>
            </div>
        }
    </div>

    @if (Model.Success)
    {
        <script>
            var t = 3;
            var el = document.getElementById('count');
            var iv = setInterval(function () {
                t--;
                el.textContent = t;
                if (t <= 0) { clearInterval(iv); window.location.href = '/'; }
            }, 1000);
        </script>
    }
</body>
</html>
