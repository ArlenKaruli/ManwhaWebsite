@page
@model ManwhaWebsite.Areas.Identity.Pages.Account.RegisterConfirmationModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Check Your Email — ManhwaVault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #0d0d12;
            --surface: #1e1e2e;
            --border: rgba(255,255,255,0.06);
            --accent: #e8445a;
            --text: #eaeaf0;
            --text-muted: #7878a0;
            --radius-sm: 8px;
            --radius-md: 14px;
            --font-display: 'Bebas Neue', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --nav-h: 68px;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-body);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        a { text-decoration: none; color: inherit; }

        nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 100;
            height: var(--nav-h);
            background: rgba(13,13,18,0.9);
            backdrop-filter: blur(20px) saturate(180%);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 24px;
        }

        .nav-logo {
            font-family: var(--font-display);
            font-size: 26px;
            letter-spacing: 2px;
            color: #fff;
        }

        .nav-logo span { color: var(--accent); }

        .page-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: calc(var(--nav-h) + 40px) 16px 60px;
        }

        .card {
            width: 100%;
            max-width: 460px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 48px 36px;
            text-align: center;
        }

        .icon {
            font-size: 48px;
            margin-bottom: 20px;
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 32px;
            letter-spacing: 2px;
            margin-bottom: 12px;
        }

        .card-title span { color: var(--accent); }

        .card-body {
            font-size: 15px;
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 8px;
        }

        .email-highlight {
            color: var(--text);
            font-weight: 600;
        }

        .card-note {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }

        .card-note a {
            color: var(--accent);
        }

        .card-note a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <nav>
        <a href="/" class="nav-logo">Manhwa<span>Vault</span></a>
    </nav>

    <div class="page-wrap">
        <div class="card">
            <div class="icon">✉️</div>
            <div class="card-title">Check Your <span>Email</span></div>
            <p class="card-body">
                We sent a confirmation link to<br />
                <span class="email-highlight">@Model.Email</span>
            </p>
            <p class="card-body">
                Click the link in the email to activate your account and start reading.
            </p>
            <div class="card-note">
                Didn't receive it? Check your spam folder, or
                <a href="/Identity/Account/Register">try registering again</a>.
            </div>
        </div>
    </div>
</body>
</html>
