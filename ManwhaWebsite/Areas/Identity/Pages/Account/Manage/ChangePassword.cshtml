@page
@model ManwhaWebsite.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    Layout = "~/Areas/Identity/Pages/Account/Manage/_Layout.cshtml";
    ViewData["Title"] = "Account Settings";
    ViewData["ActiveManagePage"] = "ChangePassword";
}

<div class="manage-card">
    <div class="manage-card-title">Account <span>Settings</span></div>
    <p class="manage-card-sub">Change your password to keep your account secure.</p>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        var isError = Model.StatusMessage.StartsWith("Error");
        <div class="manage-status @(isError ? "error" : "success")">
            @Model.StatusMessage
        </div>
    }

    <form id="change-password-form" method="post">
        <div asp-validation-summary="ModelOnly" class="manage-error-summary" id="valSummary" style="display:none"></div>

        <div class="mfield">
            <label asp-for="Input.OldPassword">Current Password</label>
            <input asp-for="Input.OldPassword" type="password" autocomplete="current-password" placeholder="••••••••" />
            <span asp-validation-for="Input.OldPassword" class="mfield-error"></span>
        </div>

        <hr class="manage-divider" />

        <div class="mfield">
            <label asp-for="Input.NewPassword">New Password</label>
            <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" placeholder="••••••••" />
            <span asp-validation-for="Input.NewPassword" class="mfield-error"></span>
        </div>

        <div class="mfield">
            <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
            <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" placeholder="••••••••" />
            <span asp-validation-for="Input.ConfirmPassword" class="mfield-error"></span>
        </div>

        <button type="submit" class="btn-vault">UPDATE PASSWORD</button>
    </form>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var vs = document.getElementById('valSummary');
            if (vs && vs.querySelectorAll('li').length > 0) vs.style.display = 'block';
        });
    </script>
}
