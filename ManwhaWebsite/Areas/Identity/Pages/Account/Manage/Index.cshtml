@page
@model ManwhaWebsite.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    Layout = "~/Areas/Identity/Pages/Account/Manage/_Layout.cshtml";
    ViewData["Title"] = "My Profile";
    ViewData["ActiveManagePage"] = "Profile";
}

<div class="manage-card">
    <div class="manage-card-title">My <span>Profile</span></div>
    <p class="manage-card-sub">Update your display name, contact info, and profile picture.</p>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        var isError = Model.StatusMessage.StartsWith("Error");
        <div class="manage-status @(isError ? "error" : "success")">
            @Model.StatusMessage
        </div>
    }

    <div class="manage-card-body">
        <div class="manage-card-form">
            <form id="profile-form" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="manage-error-summary" id="valSummary" style="display:none"></div>

                <div class="manage-user-strip">
                    <div class="manage-avatar-wrap">
                        <div class="manage-avatar">
                            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                            {
                                <img src="@Model.ProfilePictureUrl" alt="Profile picture" class="manage-avatar-img" />
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                                </svg>
                            }
                        </div>
                        <input type="file" id="ProfilePictureFile" name="ProfilePictureFile" accept="image/jpeg,image/png,image/gif,image/webp" class="avatar-file-input" />
                        <input type="hidden" id="RemoveProfilePicture" name="RemoveProfilePicture" value="false" />
                    </div>
                    <div>
                        <div class="manage-user-name">@(string.IsNullOrEmpty(Model.Input.DisplayName) ? Model.Username : Model.Input.DisplayName)</div>
                        <div class="manage-user-email">@User.Identity?.Name</div>
                        <div class="avatar-actions">
                            <label class="avatar-action-btn" for="ProfilePictureFile">Change Profile Picture</label>
                            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                            {
                                <button type="button" class="avatar-action-btn avatar-remove-btn" id="removeAvatarBtn">Remove</button>
                            }
                        </div>
                        <div class="avatar-hint">JPG, PNG, GIF or WebP &bull; Max 5 MB</div>
                    </div>
                </div>

                <div class="mfield">
                    <label asp-for="Input.DisplayName">Display Name</label>
                    <input asp-for="Input.DisplayName" type="text" placeholder="How you appear to others" maxlength="30" />
                    <span asp-validation-for="Input.DisplayName" class="mfield-error"></span>
                    <div class="mfield-hint">Max 30 characters.</div>
                </div>

                <div class="mfield">
                    <label>Username</label>
                    <input type="text" value="@Model.Username" disabled />
                    <div class="mfield-hint">Username cannot be changed.</div>
                </div>

                <div class="mfield">
                    <label asp-for="Input.PhoneNumber">Phone Number</label>
                    <input asp-for="Input.PhoneNumber" type="tel" placeholder="+1 555 000 0000" />
                    <span asp-validation-for="Input.PhoneNumber" class="mfield-error"></span>
                </div>

                <button type="submit" class="btn-vault">SAVE CHANGES</button>
            </form>
        </div>

        <div class="manage-card-stats">
            <div class="stats-section-title">Manwha <span>Statistics</span></div>
            <p class="stats-section-sub">A snapshot of your reading activity and community engagement.</p>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 14H8v-2h8v2zm0-4H8v-2h8v2zm0-4H8V6h8v2z"/></svg>
                    </div>
                    <div class="stat-text">
                        <div class="stat-value">142</div>
                        <div class="stat-label">Manwhas Read</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/></svg>
                    </div>
                    <div class="stat-text">
                        <div class="stat-value">3,847</div>
                        <div class="stat-label">Chapters Read</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18z"/></svg>
                    </div>
                    <div class="stat-text">
                        <div class="stat-value">58</div>
                        <div class="stat-label">Comments Made</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon stat-icon--up">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"/></svg>
                    </div>
                    <div class="stat-text">
                        <div class="stat-value">214</div>
                        <div class="stat-label">Upvotes Received</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon stat-icon--down">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M15 3H6c-.83 0-1.54.5-1.84 1.22l-3.02 7.05c-.09.23-.14.47-.14.73v2c0 1.1.9 2 2 2h6.31l-.95 4.57-.03.32c0 .41.17.79.44 1.06L9.83 23l6.59-6.59c.36-.36.58-.86.58-1.41V5c0-1.1-.9-2-2-2zm4 0v12h4V3h-4z"/></svg>
                    </div>
                    <div class="stat-text">
                        <div class="stat-value">12</div>
                        <div class="stat-label">Downvotes Received</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 14.24L11 13V7h1.5v5.25l4.58 2.73-1.09 1.76z"/></svg>
                    </div>
                    <div class="stat-text">
                        <div class="stat-value">18.7</div>
                        <div class="stat-label">Days Read</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var vs = document.getElementById('valSummary');
            if (vs && vs.querySelectorAll('li').length > 0) vs.style.display = 'block';

            var fileInput = document.getElementById('ProfilePictureFile');
            var removeFlag = document.getElementById('RemoveProfilePicture');
            var avatar = document.querySelector('.manage-avatar');

            fileInput.addEventListener('change', function () {
                if (!this.files || !this.files[0]) return;
                removeFlag.value = 'false';
                var reader = new FileReader();
                reader.onload = function (e) {
                    var img = avatar.querySelector('img');
                    if (!img) {
                        img = document.createElement('img');
                        img.className = 'manage-avatar-img';
                        img.alt = 'Profile picture';
                        avatar.innerHTML = '';
                        avatar.appendChild(img);
                    }
                    img.src = e.target.result;
                };
                reader.readAsDataURL(this.files[0]);
            });

            var removeBtn = document.getElementById('removeAvatarBtn');
            if (removeBtn) {
                removeBtn.addEventListener('click', function () {
                    removeFlag.value = 'true';
                    fileInput.value = '';
                    avatar.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>';
                    removeBtn.style.display = 'none';
                });
            }
        });
    </script>
}
