@model ManwhaWebsite.Models.HomeViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ManhwaVault — Discover Your Next Obsession</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Noto+Serif+KR:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
</head>
<body>

    <!-- NAV -->
    <nav class="nav">
        <div class="nav-inner">
            <a href="#" class="nav-logo">Manhwa<span>Vault</span></a>
            <div class="nav-search">
                <span class="nav-search-icon">⌕</span>
                <input type="text" placeholder="Search titles, genres, authors..." />
            </div>
            <ul class="nav-links">
                <li><a href="#">Browse</a></li>
                <li><a href="#">Genres</a></li>
                <li><a href="#">Rankings</a></li>
                <li><a href="#">Latest</a></li>
            </ul>
            <div class="nav-right">
                <a href="#" class="btn-login">Sign In</a>
                <a href="#" class="btn-signup">Join Free</a>
                <button class="nav-hamburger" onclick="toggleDrawer()">☰</button>
            </div>
        </div>
    </nav>

    <!-- Mobile Drawer -->
    <div class="nav-drawer" id="navDrawer" onclick="toggleDrawer()">
        <div class="nav-drawer-panel" onclick="event.stopPropagation()">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;margin-bottom:12px;">
                Manhwa<span style="color:var(--accent)">Vault</span>
            </div>
            <a href="#">Browse</a>
            <a href="#">Genres</a>
            <a href="#">Rankings</a>
            <a href="#">Latest</a>
            <hr style="border-color:var(--border);margin:8px 0" />
            <a href="#">Sign In</a>
            <a href="#">Join Free</a>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         HERO — from Model.Trending
    ══════════════════════════════════════════ -->
    <section class="hero">
        <div class="hero-slides" id="heroSlides">
            @{
                int heroIdx = 0;
            }
            @foreach (var item in Model.Trending)
            {
                var bgUrl = !string.IsNullOrEmpty(item.BannerImageUrl) ? item.BannerImageUrl : item.CoverImageUrl;
                <div class="hero-slide @(heroIdx == 0 ? "active" : "")" data-index="@heroIdx">
                    <div class="hero-slide-bg hero-slide-bg--blurred" style="background-image:url('@bgUrl')"></div>
                    <div class="hero-slide-cover-wrap">
                        <img src="@item.CoverImageUrl" alt="@item.Title" loading="eager" />
                    </div>
                    <div class="hero-slide-overlay"></div>
                    <div class="hero-content">
                        <div class="container">
                            <h1 class="hero-title">@item.Title</h1>
                            <div class="hero-meta">
                                <span class="hero-rank">#@(heroIdx + 1) Trending</span>
                            </div>
                            <p class="hero-desc">@item.Description</p>
                            <div class="hero-stats">
                                <div class="hero-stat" style="color:var(--gold)">★ @item.Rating.ToString("F1")</div>
                                <div class="hero-stat">👁 <strong>@FormatNum(item.Popularity)</strong> readers</div>
                                <div class="hero-stat">🕐 <strong>@item.LastUpdated.ToString("MMM dd")</strong></div>
                            </div>
                            <div class="hero-actions">
                                <a href="https://anilist.co/manga/@item.Id" target="_blank" class="btn-hero-primary">▶ View Details</a>
                                <a href="https://anilist.co/manga/@item.Id" target="_blank" class="btn-hero-secondary">+ Add to List</a>
                            </div>
                        </div>
                    </div>
                </div>
                heroIdx++;
            }
        </div>

        <!-- Thumb strip -->
        <div class="hero-thumbs">
            @{
                int thumbIdx = 0;
            }
            @foreach (var item in Model.Trending)
            {
                <div class="hero-thumb @(thumbIdx == 0 ? "active" : "")" onclick="goToSlide(@thumbIdx)">
                    <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                </div>
                thumbIdx++;
            }
        </div>

        <!-- Dots -->
        <div class="hero-dots">
            @for (int d = 0; d < Model.Trending.Count(); d++)
            {
                <div class="hero-dot @(d == 0 ? "active" : "")" onclick="goToSlide(@d)"></div>
            }
        </div>
    </section>

    <!-- GENRE PILLS -->
    <div class="genres-band">
        <div class="genres-scroll">
            <a href="#" class="genre-pill active">All</a>
            <a href="#" class="genre-pill">Action</a>
            <a href="#" class="genre-pill">Romance</a>
            <a href="#" class="genre-pill">Fantasy</a>
            <a href="#" class="genre-pill">System</a>
            <a href="#" class="genre-pill">Regression</a>
            <a href="#" class="genre-pill">Isekai</a>
            <a href="#" class="genre-pill">Martial Arts</a>
            <a href="#" class="genre-pill">Horror</a>
            <a href="#" class="genre-pill">Comedy</a>
            <a href="#" class="genre-pill">Drama</a>
            <a href="#" class="genre-pill">Cultivation</a>
            <a href="#" class="genre-pill">Thriller</a>
            <a href="#" class="genre-pill">Historical</a>
            <a href="#" class="genre-pill">Slice of Life</a>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         POPULAR — from Model.Popular
    ══════════════════════════════════════════ -->
    <section class="section-popular">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">🔥 <span>Popular</span> Right Now</h2>
                <a href="#" class="view-all">View All →</a>
            </div>
            <div class="scroll-row-wrapper">
                <button class="scroll-btn scroll-btn-left" onclick="scrollRow('popularRow',-1)">‹</button>
                <div class="scroll-row" id="popularRow">
                    @{
                        int popIdx = 0;
                    }
                    @foreach (var item in Model.Popular)
                    {
                        <div class="card">
                            <div class="card-cover">
                                <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                                <div class="card-overlay">
                                    <a href="https://anilist.co/manga/@item.Id" target="_blank" class="card-overlay-read">▶ View Details</a>
                                </div>
                            </div>
                            <div class="card-info">
                                <div class="card-title">@item.Title</div>
                                <div class="card-meta">
                                    <span class="card-rating">@item.Rating.ToString("F1")</span>
                                    <span class="card-views">@FormatNum(item.Popularity)</span>
                                </div>
                            </div>
                        </div>
                        popIdx++;
                    }
                </div>
                <button class="scroll-btn scroll-btn-right" onclick="scrollRow('popularRow',1)">›</button>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════
         NEWLY UPDATED — from Model.NewlyUpdated
    ══════════════════════════════════════════ -->
    <section class="section-updated">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">🆕 <span>Newly</span> Updated</h2>
                <a href="#" class="view-all">View All →</a>
            </div>
            <div class="updated-grid">
                @foreach (var item in Model.NewlyUpdated)
                {
                    var isNew = (DateTime.UtcNow - item.LastUpdated).TotalHours < 24;
                    <a href="https://anilist.co/manga/@item.Id" target="_blank" class="updated-card">
                        <div class="updated-cover">
                            <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                            @if (isNew)
                            {
                                <div class="updated-cover-badge"><span class="badge badge-new">New</span></div>
                            }
                        </div>
                        <div class="updated-info">
                            <div class="updated-title">@item.Title</div>
                            <div class="updated-chapter">@(item.LatestChapter ?? item.Status)</div>
                            <div class="updated-time">@GetTimeAgo(item.LastUpdated)</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════
         DISCOVER — from Model.Random
    ══════════════════════════════════════════ -->
    <section class="section-discover">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">✨ <span>Discover</span> Something New</h2>
                <a href="#" class="view-all">Randomize →</a>
            </div>
            <div class="discover-grid">
                @foreach (var item in Model.Random)
                {
                    <a href="https://anilist.co/manga/@item.Id" target="_blank" class="discover-card">
                        <div class="discover-cover">
                            <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                        </div>
                        <div class="discover-body">
                            <div class="discover-title">@item.Title</div>
                            <div class="discover-desc">@item.Description</div>
                            <div class="discover-footer">
                                <span class="discover-rating">@item.Rating.ToString("F1")</span>
                                <span class="discover-views">@FormatNum(item.Popularity) readers</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="footer-inner">
                <div class="footer-brand">
                    <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;">
                        Manhwa<span style="color:var(--accent)">Vault</span>
                    </div>
                    <p>Your ultimate destination for manhwa, manhua, and manga. Track your list, discover new titles, and connect with the community.</p>
                </div>
                <div class="footer-col"><h4>Browse</h4><ul><li><a href="#">Popular</a></li><li><a href="#">Latest</a></li><li><a href="#">Rankings</a></li><li><a href="#">Genres</a></li></ul></div>
                <div class="footer-col"><h4>Account</h4><ul><li><a href="#">Sign Up</a></li><li><a href="#">Login</a></li><li><a href="#">Reading List</a></li><li><a href="#">Settings</a></li></ul></div>
                <div class="footer-col"><h4>Info</h4><ul><li><a href="#">About</a></li><li><a href="#">Contact</a></li><li><a href="#">Privacy</a></li><li><a href="#">Terms</a></li></ul></div>
            </div>
            <div class="footer-bottom">
                <span>© @DateTime.Now.Year ManhwaVault. All rights reserved.</span>
                <span>Made for readers, by readers.</span>
            </div>
        </div>
    </footer>

    <script>
        // ── HERO SLIDER ──────────────────────────────────────────────
        let currentSlide = 0;
        const slides = document.querySelectorAll('.hero-slide');
        const thumbs = document.querySelectorAll('.hero-thumb');
        const dots   = document.querySelectorAll('.hero-dot');
        let autoplayTimer;

        function goToSlide(idx) {
            slides[currentSlide].classList.remove('active');
            thumbs[currentSlide]?.classList.remove('active');
            dots[currentSlide]?.classList.remove('active');
            currentSlide = (idx + slides.length) % slides.length;
            slides[currentSlide].classList.add('active');
            thumbs[currentSlide]?.classList.add('active');
            dots[currentSlide]?.classList.add('active');
            resetAutoplay();
        }
        function resetAutoplay() {
            clearInterval(autoplayTimer);
            autoplayTimer = setInterval(() => goToSlide(currentSlide + 1), 5500);
        }
        document.addEventListener('keydown', e => {
            if (e.key === 'ArrowRight') goToSlide(currentSlide + 1);
            if (e.key === 'ArrowLeft')  goToSlide(currentSlide - 1);
        });
        (function () {
            let startX = 0;
            const hero = document.querySelector('.hero');
            hero.addEventListener('touchstart', e => startX = e.touches[0].clientX, { passive: true });
            hero.addEventListener('touchend', e => {
                const dx = e.changedTouches[0].clientX - startX;
                if (Math.abs(dx) > 50) goToSlide(currentSlide + (dx < 0 ? 1 : -1));
            });
        })();
        resetAutoplay();

        function scrollRow(id, dir) {
            document.getElementById(id)?.scrollBy({ left: dir * 480, behavior: 'smooth' });
        }
        function toggleDrawer() {
            document.getElementById('navDrawer')?.classList.toggle('open');
        }

        // Scroll reveal
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.style.opacity = '1';
                    e.target.style.transform = 'translateY(0)';
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.06 });
        document.querySelectorAll('.updated-card, .discover-card, .card').forEach((el, i) => {
            el.style.cssText += `opacity:0;transform:translateY(18px);transition:opacity 0.45s ease ${Math.min(i * 0.04, 0.4)}s,transform 0.45s ease ${Math.min(i * 0.04, 0.4)}s`;
            observer.observe(el);
        });
    </script>

    @functions {
        string FormatNum(int n)
        {
            if (n >= 1_000_000) return $"{n / 1_000_000.0:F1}M";
            if (n >= 1_000) return $"{n / 1_000.0:F0}K";
            return n.ToString();
        }
        string GetTimeAgo(DateTime dt)
        {
            var span = DateTime.UtcNow - dt;
            if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
            if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
            if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
            return dt.ToString("MMM dd");
        }
    }

</body>
</html>