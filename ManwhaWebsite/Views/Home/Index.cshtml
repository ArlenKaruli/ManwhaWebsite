@model ManwhaWebsite.Models.HomeViewModel
@using ManwhaWebsite.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var _homePic = SignInManager.IsSignedIn(User) ? (await UserManager.GetUserAsync(User))?.ProfilePictureUrl : null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ManhwaVault — Discover Your Next Obsession</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Noto+Serif+KR:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
</head>
<body>

    <!-- NAV -->
    <nav class="nav">
        <div class="nav-inner">
            <a href="#" class="nav-logo">Manhwa<span>Vault</span></a>
            <div class="nav-search">
                <span class="nav-search-icon">⌕</span>
                <input id="navSearchInput" type="text" placeholder="Search titles, genres, authors..." autocomplete="off" />
            </div>
            <button class="nav-search-toggle" aria-label="Search" onclick="toggleMobileSearch()">
                <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
            <div class="nav-search-overlay" id="navSearchOverlay">
                <div class="nav-search-overlay-inner">
                    <input id="mobileSearchInput" type="text" placeholder="Search titles, genres, authors..." />
                    <button class="nav-search-close" onclick="toggleMobileSearch()" aria-label="Close search">✕</button>
                </div>
            </div>
            <div class="nav-actions">
                <div class="nav-links">
                    <div><a href="/Browse">Browse</a></div>
                    <div><a href="/Popular">Popular</a></div>
                    <div><a href="/Rankings">Rankings</a></div>
                    <div><a href="/Latest">Latest</a></div>
                </div>
                <div class="nav-right">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="nav-account-dropdown" id="profileDropdown">
                            <button class="nav-account-btn @(_homePic != null ? "has-pic" : "")" onclick="toggleProfileMenu(event)" aria-label="Account menu" aria-expanded="false" aria-controls="profileMenu">
                                @if (_homePic != null)
                                {
                                    <img src="@_homePic" alt="Profile" class="nav-account-pic" />
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                                    </svg>
                                }
                            </button>
                            <div class="nav-account-menu" id="profileMenu" role="menu">
                                <a href="/Identity/Account/Manage" class="nav-account-menu-item" role="menuitem">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
                                    My Profile
                                </a>
                                <a href="/ReadingList" class="nav-account-menu-item" role="menuitem">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-6 3a3 3 0 1 1 0 6 3 3 0 0 1 0-6zm4 13H8v-.9c0-2 4-3.1 6-3.1s6 1.1 6 3.1V18z"/></svg>
                                    My Reading List
                                </a>
                                <a href="/Identity/Account/Manage/ChangePassword" class="nav-account-menu-item" role="menuitem">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.3.06-.61.06-.94s-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96a7.01 7.01 0 0 0-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.48.48 0 0 0-.59.22L2.74 8.87a.47.47 0 0 0 .12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.47.47 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.37 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.57 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32a.47.47 0 0 0-.12-.61l-2.03-1.58zM12 15.6a3.6 3.6 0 1 1 0-7.2 3.6 3.6 0 0 1 0 7.2z"/></svg>
                                    Account Settings
                                </a>
                                <div class="nav-account-menu-divider"></div>
                                <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                    <button type="submit" class="nav-account-menu-item nav-account-menu-logout" role="menuitem">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zm-5 10H5V7h7V5H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h7v-2z"/></svg>
                                        Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login" class="btn-login">Sign In</a>
                        <a href="/Identity/Account/Register" class="btn-signup">Join Free</a>
                    }
                    <button class="nav-hamburger" onclick="toggleDrawer()">☰</button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile Drawer -->
    <div class="nav-drawer" id="navDrawer" onclick="toggleDrawer()">
        <div class="nav-drawer-panel" onclick="event.stopPropagation()">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;margin-bottom:12px;">
                Manhwa<span style="color:var(--accent)">Vault</span>
            </div>
            <a href="/Browse">Browse</a>
            <a href="/Popular">Popular</a>
            <a href="/Rankings">Rankings</a>
            <a href="/Latest">Latest</a>
            <hr style="border-color:var(--border);margin:8px 0" />
            @if (!SignInManager.IsSignedIn(User))
            {
                <a href="/Identity/Account/Login">Sign In</a>
                <a href="/Identity/Account/Register">Join Free</a>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         HERO — from Model.Trending
    ══════════════════════════════════════════ -->
    <section class="hero">
        <div class="hero-slides" id="heroSlides">
            @{
                int heroIdx = 0;
            }
            @foreach (var item in Model.Trending)
            {
                var bgUrl = !string.IsNullOrEmpty(item.BannerImageUrl) ? item.BannerImageUrl : item.CoverImageUrl;
                <div class="hero-slide @(heroIdx == 0 ? "active" : "")" data-index="@heroIdx">
                    <div class="hero-slide-bg hero-slide-bg--blurred" style="background-image:url('@bgUrl')"></div>
                    <div class="hero-slide-cover-wrap">
                        <img src="@item.CoverImageUrl" alt="@item.Title" loading="eager" />
                    </div>
                    <div class="hero-slide-overlay"></div>
                    <div class="hero-content">
                        <div class="container">
                            <h1 class="hero-title">@item.Title</h1>
                            <div class="hero-meta">
                                <span class="hero-rank">#@(heroIdx + 1) Trending</span>
                            </div>
                            <p class="hero-desc">@item.Description</p>
                            <div class="hero-stats">
                                <div class="hero-stat" style="color:var(--gold)">★ @item.Rating.ToString("F1")</div>
                                <div class="hero-stat">👁 <strong>@FormatNum(item.Popularity)</strong> readers</div>
                                <div class="hero-stat">🕐 <strong>@item.LastUpdated.ToString("MMM dd")</strong></div>
                            </div>
                            <div class="hero-actions">
                                <a href="/manga/@item.Id" class="btn-hero-primary">▶ View Details</a>
                                <a href="/manga/@item.Id" class="btn-hero-secondary">+ Add to List</a>
                            </div>
                        </div>
                    </div>
                </div>
                heroIdx++;
            }
        </div>

        <!-- Thumb strip -->
        <div class="hero-thumbs">
            @{
                int thumbIdx = 0;
            }
            @foreach (var item in Model.Trending)
            {
                <div class="hero-thumb @(thumbIdx == 0 ? "active" : "")" onclick="goToSlide(@thumbIdx)">
                    <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                </div>
                thumbIdx++;
            }
        </div>

        <!-- Dots -->
        <div class="hero-dots">
            @for (int d = 0; d < Model.Trending.Count(); d++)
            {
                <div class="hero-dot @(d == 0 ? "active" : "")" onclick="goToSlide(@d)"></div>
            }
        </div>
    </section>


    <!-- ══════════════════════════════════════════
         POPULAR — from Model.Popular
    ══════════════════════════════════════════ -->
    <section class="section-popular">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">🔥 <span>Popular</span></h2>
                <a href="/Popular" class="view-all">View All →</a>
            </div>
            <div class="scroll-row-wrapper">
                <button class="scroll-btn scroll-btn-left" onclick="scrollRow('popularRow',-1)">‹</button>
                <div class="scroll-row" id="popularRow" data-base-count="15">
                    @{
                        int popIdx = 0;
                    }
                    @foreach (var item in Model.Popular)
                    {
                        <a href="/manga/@item.Id" class="card">
                            <div class="card-cover">
                                <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                            </div>
                            <div class="card-info">
                                <div class="card-title">@item.Title</div>
                                <div class="card-meta">
                                    <span class="card-rating">@item.Rating.ToString("F1")</span>
                                    <span class="card-views">@FormatNum(item.Popularity)</span>
                                </div>
                            </div>
                        </a>
                        popIdx++;
                    }
                </div>
                <button class="scroll-btn scroll-btn-right" onclick="scrollRow('popularRow',1)">›</button>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════
         RECOMMENDED FOR YOU
    ══════════════════════════════════════════ -->
    <section class="section-popular">
        <div class="container">
            <div class="section-header">
                <div>
                    <h2 class="section-title">⭐ Recommended <span>For You</span></h2>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="recommended-hint" id="recommendedHint">
                            <span class="recommended-hint-icon">✦</span>
                            <span>Tailored to your taste — gets smarter as you log what you've read.</span>
                            <button class="recommended-hint-dismiss" onclick="dismissRecommendedHint()" aria-label="Dismiss">✕</button>
                        </div>
                    }
                </div>
            </div>
            @if (SignInManager.IsSignedIn(User))
            {
                <input type="hidden" id="rec-token" value="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
                <div class="scroll-row-wrapper">
                    <button class="scroll-btn scroll-btn-left" onclick="scrollRow('recommendedRow',-1)">‹</button>
                    <div class="scroll-row" id="recommendedRow" data-base-count="15">
                        @foreach (var item in Model.Recommendations)
                        {
                            <div class="rec-card-wrapper" style="flex-shrink:0">
                                <a href="/manga/@item.Id" class="card">
                                    <div class="card-cover">
                                        <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                                        <div class="card-overlay">
                                            <div class="card-overlay-read"
                                                 role="button" tabindex="0"
                                                 data-anilist-id="@item.Id"
                                                 data-title="@item.Title"
                                                 data-cover="@item.CoverImageUrl"
                                                 data-status="@(item.ChapterCount != null ? "Completed" : "Reading")"
                                                 onclick="markRead(event, this)"
                                                 onkeydown="if(event.key==='Enter'||event.key===' ')markRead(event,this)">
                                                @(item.ChapterCount != null ? "Already Read" : "Currently Reading")
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-info">
                                        <div class="card-title">@item.Title</div>
                                        <div class="card-meta">
                                            <span class="card-rating">@item.Rating.ToString("F1")</span>
                                            <span class="card-views">@FormatNum(item.Popularity)</span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                    <button class="scroll-btn scroll-btn-right" onclick="scrollRow('recommendedRow',1)">›</button>
                </div>
            }
            else
            {
                <div class="recommended-signin">
                    <p>Sign in to get personalized recommendations.</p>
                    <a href="/Identity/Account/Login" class="recommended-signin-btn">Sign In</a>
                </div>
            }
        </div>
    </section>

    <!-- ══════════════════════════════════════════
         NEWLY UPDATED — from Model.NewlyUpdated
    ══════════════════════════════════════════ -->
    <section class="section-updated">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">🆕 <span>Newly</span> Updated</h2>
                <a href="/Latest" class="view-all">View All →</a>
            </div>
            <div class="updated-grid" data-base-count="9">
                @foreach (var item in Model.NewlyUpdated)
                {
                    var isNew = (DateTime.UtcNow - item.LastUpdated).TotalHours < 24;
                    <a href="/manga/@item.Id" class="updated-card">
                        <div class="updated-cover">
                            <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                            @if (isNew)
                            {
                                <div class="updated-cover-badge"><span class="badge badge-new">New</span></div>
                            }
                        </div>
                        <div class="updated-info">
                            <div class="updated-title">@item.Title</div>
                            <div class="updated-chapter">@(item.LatestChapter ?? item.Status)</div>
                            <div class="updated-time">@GetTimeAgo(item.LastUpdated)</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════
         DISCOVER — from Model.Random
    ══════════════════════════════════════════ -->
    <section class="section-discover">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">✨ <span>Discover</span> Something New</h2>
                <button class="view-all discover-randomize-btn" id="discoverRandomizeBtn" onclick="randomizeDiscover()">↺ Randomize</button>
            </div>

            <div class="discover-grid" data-base-count="6">
                @foreach (var item in Model.Random)
                {
                    <a href="/manga/@item.Id" class="discover-card"
                       data-genres="@string.Join("|", item.Genres)"
                       data-status="@item.Status"
                       data-rating="@item.Rating.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                       data-chapters="@(item.ChapterCount?.ToString() ?? "0")">
                        <div class="discover-cover">
                            <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                        </div>
                        <div class="discover-body">
                            <div class="discover-title">@item.Title</div>
                            <div class="discover-desc">@item.Description</div>
                            <div class="discover-footer">
                                <span class="discover-rating">@item.Rating.ToString("F1")</span>
                                <span class="discover-views">@FormatNum(item.Popularity) readers</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="footer-inner">
                <div class="footer-brand">
                    <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;">
                        Manhwa<span style="color:var(--accent)">Vault</span>
                    </div>
                    <p>Your ultimate destination for manhwa, manhua, and manga. Track your list, discover new titles, and connect with the community.</p>
                </div>
                <div class="footer-col"><h4>Browse</h4><ul><li><a href="/Browse">Browse</a></li><li><a href="/Popular">Popular</a></li><li><a href="/Rankings">Rankings</a></li><li><a href="/Latest">Latest</a></li></ul></div>
                <div class="footer-col"><h4>Info</h4><ul><li><a href="/Static/About">About</a></li><li><a href="/Static/Contact">Contact</a></li><li><a href="/Static/Privacy">Privacy</a></li><li><a href="/Static/Terms">Terms</a></li></ul></div>
            </div>
            <div class="footer-bottom">
                <span>© @DateTime.Now.Year ManhwaVault. All rights reserved.</span>
                <span>Made for readers, by readers.</span>
            </div>
        </div>
    </footer>

    <script>
        // ── HERO SLIDER ──────────────────────────────────────────────
        let currentSlide = 0;
        const slides = document.querySelectorAll('.hero-slide');
        const thumbs = document.querySelectorAll('.hero-thumb');
        const dots   = document.querySelectorAll('.hero-dot');
        let autoplayTimer;

        function goToSlide(idx) {
            slides[currentSlide].classList.remove('active');
            thumbs[currentSlide]?.classList.remove('active');
            dots[currentSlide]?.classList.remove('active');
            currentSlide = (idx + slides.length) % slides.length;
            slides[currentSlide].classList.add('active');
            thumbs[currentSlide]?.classList.add('active');
            dots[currentSlide]?.classList.add('active');
            resetAutoplay();
        }
        function resetAutoplay() {
            clearInterval(autoplayTimer);
            autoplayTimer = setInterval(() => goToSlide(currentSlide + 1), 5500);
        }
        document.addEventListener('keydown', e => {
            if (e.key === 'ArrowRight') goToSlide(currentSlide + 1);
            if (e.key === 'ArrowLeft')  goToSlide(currentSlide - 1);
        });
        (function () {
            let startX = 0;
            const hero = document.querySelector('.hero');
            hero.addEventListener('touchstart', e => startX = e.touches[0].clientX, { passive: true });
            hero.addEventListener('touchend', e => {
                const dx = e.changedTouches[0].clientX - startX;
                if (Math.abs(dx) > 50) goToSlide(currentSlide + (dx < 0 ? 1 : -1));
            });
        })();
        resetAutoplay();

        function scrollRow(id, dir) {
            document.getElementById(id)?.scrollBy({ left: dir * 480, behavior: 'smooth' });
        }

        function applyGridFill(gridEl) {
            if (!gridEl) return;
            const all = Array.from(gridEl.children);
            if (!all.length) return;
            // reset only items that aren't hidden by the filter
            all.forEach(el => { if (!el.dataset.filteredOut) el.style.display = ''; });
            const cols = getComputedStyle(gridEl).gridTemplateColumns.split(' ').length;
            if (cols <= 1) return;
            const pool = all.filter(el => !el.dataset.filteredOut);
            const base = parseInt(gridEl.dataset.baseCount) || pool.length;
            const ideal = Math.ceil(base / cols) * cols;
            const avail = Math.floor(pool.length / cols) * cols;
            const show = avail >= ideal ? ideal : (avail || pool.length);
            pool.forEach((el, i) => {
                el.style.display = i < show ? '' : 'none';
                if (i < show && el.style.opacity === '0') { el.style.opacity = '1'; el.style.transform = ''; }
            });
        }
        function applyGridFills() {
            applyGridFill(document.getElementById('popularRow'));
            applyGridFill(document.querySelector('.updated-grid'));
            applyGridFill(document.querySelector('.discover-grid'));
        }
        applyGridFills();
        let fillTimer;
        window.addEventListener('resize', () => {
            clearTimeout(fillTimer);
            fillTimer = setTimeout(() => {
                applyGridFills();
                if (window.innerWidth > 768) {
                    document.getElementById('filterBackdrop')?.classList.remove('visible');
                    document.body.style.overflow = '';
                }
            }, 100);
        });

        // ── DISCOVER RANDOMIZE ───────────────────────────────────────
        async function randomizeDiscover() {
            const btn  = document.getElementById('discoverRandomizeBtn');
            const grid = document.querySelector('.discover-grid');
            btn.disabled = true;
            btn.textContent = '↻ Loading…';
            grid.style.opacity = '0.4';
            grid.style.pointerEvents = 'none';
            try {
                const res = await fetch('/Home/RandomDiscover');
                if (!res.ok) throw new Error();
                const items = await res.json();
                grid.innerHTML = items.map(m => {
                    const score = m.score > 0 ? m.score.toFixed(1) : '—';
                    const pop   = m.popularity > 1000
                        ? (m.popularity / 1000).toFixed(1) + 'k'
                        : String(m.popularity);
                    const desc  = m.description
                        ? m.description.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                        : '';
                    return `<a href="/manga/${m.id}" class="discover-card">
                        <div class="discover-cover"><img src="${m.cover||''}" alt="" loading="lazy"></div>
                        <div class="discover-body">
                            <div class="discover-title">${m.title||''}</div>
                            <div class="discover-desc">${desc}</div>
                            <div class="discover-footer">
                                <span class="discover-rating">${score}</span>
                                <span class="discover-views">${pop} readers</span>
                            </div>
                        </div>
                    </a>`;
                }).join('');
                applyGridFill(grid);
            } catch (e) {
                // silently restore on error
            } finally {
                grid.style.opacity = '';
                grid.style.pointerEvents = '';
                btn.disabled = false;
                btn.textContent = '↺ Randomize';
            }
        }
        function toggleDrawer() {
            document.getElementById('navDrawer')?.classList.toggle('open');
        }
        function toggleMobileSearch() {
            const overlay = document.getElementById('navSearchOverlay');
            const isOpen = overlay.classList.toggle('is-open');
            if (isOpen) {
                document.getElementById('mobileSearchInput').focus();
            }
        }
        document.getElementById('navSearchOverlay')?.addEventListener('click', function(e) {
            if (e.target === this) toggleMobileSearch();
        });

        function toggleProfileMenu(e) {
            e.stopPropagation();
            const dropdown = document.getElementById('profileDropdown');
            const menu = document.getElementById('profileMenu');
            const btn = dropdown.querySelector('.nav-account-btn');
            const open = dropdown.classList.toggle('open');
            btn.setAttribute('aria-expanded', open);
            if (!open) menu.classList.remove('open');
        }
        document.addEventListener('click', function(e) {
            const dropdown = document.getElementById('profileDropdown');
            if (dropdown && !dropdown.contains(e.target)) {
                dropdown.classList.remove('open');
                dropdown.querySelector('.nav-account-btn')?.setAttribute('aria-expanded', 'false');
            }
        });

        // Recommended hint — hidden permanently once user has logged a read manhwa
        (function () {
            const hint = document.getElementById('recommendedHint');
            if (hint && localStorage.getItem('hasReadManwha')) hint.style.display = 'none';
        })();

        function dismissRecommendedHint() {
            localStorage.setItem('hasReadManwha', '1');
            const hint = document.getElementById('recommendedHint');
            if (!hint) return;
            hint.classList.add('recommended-hint--dismissed');
            hint.addEventListener('animationend', () => hint.style.display = 'none', { once: true });
        }

        function markRead(event, el) {
            event.preventDefault();
            event.stopPropagation();

            const wrapper = el.closest('.rec-card-wrapper');
            const token = document.getElementById('rec-token').value;

            el.textContent = '…';
            el.style.pointerEvents = 'none';

            const body = new URLSearchParams({
                aniListId: el.dataset.anilistId,
                title: el.dataset.title,
                coverImageUrl: el.dataset.cover,
                status: el.dataset.status,
                __RequestVerificationToken: token
            });

            fetch('/ReadingList/MarkStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    wrapper.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                    wrapper.style.opacity = '0';
                    wrapper.style.transform = 'scale(0.9)';
                    setTimeout(() => wrapper.remove(), 320);
                }
            })
            .catch(() => {
                el.textContent = 'Already Read';
                el.style.pointerEvents = '';
            });
        }

        // Scroll reveal
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.style.opacity = '1';
                    e.target.style.transform = 'translateY(0)';
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.06 });
        document.querySelectorAll('.updated-card, .discover-card, .card').forEach((el, i) => {
            el.style.cssText += `opacity:0;transform:translateY(18px);transition:opacity 0.45s ease ${Math.min(i * 0.04, 0.4)}s,transform 0.45s ease ${Math.min(i * 0.04, 0.4)}s`;
            observer.observe(el);
        });
    </script>

    <script src="~/js/search.js" asp-append-version="true"></script>

    @functions {
        string FormatNum(int n)
        {
            if (n >= 1_000_000) return $"{n / 1_000_000.0:F1}M";
            if (n >= 1_000) return $"{n / 1_000.0:F0}K";
            return n.ToString();
        }
        string GetTimeAgo(DateTime dt)
        {
            var span = DateTime.UtcNow - dt;
            if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
            if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
            if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
            return dt.ToString("MMM dd");
        }
    }

</body>
