@{
    Layout = "~/Views/Shared/_VaultLayout.cshtml";
    ViewData["Title"] = "Contact";
}

@section Styles {
    <link rel="stylesheet" href="~/css/static-pages.css" asp-append-version="true" />
}

<div class="static-page">

    <a href="/" class="static-back">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
        Back to Home
    </a>

    <div class="static-hero">
        <span class="static-hero-label">Get in Touch</span>
        <h1>Contact Us</h1>
        <p>Have a question, found a bug, or just want to say hello? We'd love to hear from you.</p>
    </div>

    <div class="static-contact-cards">
        <div class="static-contact-card">
            <div class="static-contact-card-icon">&#9993;</div>
            <h3>General Enquiries</h3>
            <p><a href="mailto:hello@manhwavault.com">hello@@manhwavault.com</a></p>
        </div>
        <div class="static-contact-card">
            <div class="static-contact-card-icon">&#128030;</div>
            <h3>Bug Reports</h3>
            <p><a href="mailto:bugs@manhwavault.com">bugs@@manhwavault.com</a></p>
        </div>
        <div class="static-contact-card">
            <div class="static-contact-card-icon">&#128274;</div>
            <h3>Privacy &amp; Legal</h3>
            <p><a href="mailto:legal@manhwavault.com">legal@@manhwavault.com</a></p>
        </div>
    </div>

    <div class="static-section">
        <h2>Send a Message</h2>
        <p>Fill in the form below and we'll get back to you within 2 business days.</p>

        <form class="static-form" id="contactForm" onsubmit="handleContact(event)">
            @Html.AntiForgeryToken()
            <div class="static-form-row">
                <div class="static-field">
                    <label for="contactName">Name</label>
                    <input type="text" id="contactName" name="name" placeholder="Your name" required />
                </div>
                <div class="static-field">
                    <label for="contactEmail">Email</label>
                    <input type="email" id="contactEmail" name="email" placeholder="you@@example.com" required />
                </div>
            </div>
            <div class="static-field">
                <label for="contactSubject">Subject</label>
                <select id="contactSubject" name="subject">
                    <option value="General Question">General Question</option>
                    <option value="Bug Report">Bug Report</option>
                    <option value="Feature Request">Feature Request</option>
                    <option value="Content Issue">Content Issue</option>
                    <option value="Legal / Privacy">Legal / Privacy</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="static-field">
                <label for="contactMessage">Message</label>
                <textarea id="contactMessage" name="message" placeholder="Tell us what's on your mind..." required></textarea>
            </div>
            <div id="contactStatus" style="display:none;margin-bottom:12px;font-size:14px;"></div>
            <button type="submit" class="static-submit" id="contactBtn">Send Message</button>
        </form>
    </div>

    <div class="static-divider"></div>

    <div class="static-section">
        <h2>Response Times</h2>
        <ul>
            <li>General enquiries — within 2 business days</li>
            <li>Bug reports — acknowledged within 24 hours</li>
            <li>Legal &amp; privacy requests — within 5 business days</li>
        </ul>
    </div>

</div>

<footer>
    <div class="container">
        <div class="footer-inner">
            <div class="footer-brand">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;">
                    Manhwa<span style="color:var(--accent)">Vault</span>
                </div>
                <p>Your ultimate destination for manhwa, manhua, and manga. Track your list, discover new titles, and connect with the community.</p>
            </div>
            <div class="footer-col"><h4>Browse</h4><ul><li><a href="/Browse">Browse</a></li><li><a href="/Popular">Popular</a></li><li><a href="/Rankings">Rankings</a></li><li><a href="/Latest">Latest</a></li></ul></div>
            <div class="footer-col"><h4>Info</h4><ul><li><a href="/Static/About">About</a></li><li><a href="/Static/Contact">Contact</a></li><li><a href="/Static/Privacy">Privacy</a></li><li><a href="/Static/Terms">Terms</a></li></ul></div>
        </div>
        <div class="footer-bottom">
            <span>&copy; @DateTime.Now.Year ManhwaVault. All rights reserved.</span>
            <span>Made for readers, by readers.</span>
        </div>
    </div>
</footer>

@section Scripts {
<script>
async function handleContact(e) {
    e.preventDefault();
    const form = document.getElementById('contactForm');
    const btn = document.getElementById('contactBtn');
    const status = document.getElementById('contactStatus');

    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.style.display = 'none';

    const body = new URLSearchParams(new FormData(form));

    try {
        const res = await fetch('/Static/Contact', { method: 'POST', body });
        const data = await res.json();
        if (data.ok) {
            form.reset();
            btn.textContent = 'Sent!';
            btn.style.opacity = '0.6';
            status.style.color = '#4caf50';
            status.textContent = "Your message has been sent. We'll get back to you within 2 business days.";
        } else {
            btn.disabled = false;
            btn.textContent = 'Send Message';
            status.style.color = '#e8445a';
            status.textContent = data.error ?? 'Something went wrong. Please try again.';
        }
    } catch {
        btn.disabled = false;
        btn.textContent = 'Send Message';
        status.style.color = '#e8445a';
        status.textContent = 'Network error. Please try again.';
    }

    status.style.display = 'block';
}
</script>
}
