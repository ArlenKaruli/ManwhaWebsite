@model ManwhaWebsite.Models.UserProfileViewModel
@{
    Layout = "~/Views/Shared/_VaultLayout.cshtml";
    ViewData["Title"] = $"{Model.DisplayName}'s Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/user-search.css" asp-append-version="true" />
}

<div class="up-page">

    <div class="up-banner">
        <div class="up-banner-inner">
            <div class="up-avatar">
                @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                {
                    <img src="@Model.ProfilePictureUrl" alt="@Model.DisplayName" />
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                }
            </div>
            <div class="up-info">
                <div class="up-name">@Model.DisplayName</div>
                <div class="up-joined">Member since @Model.JoinedAt.ToString("MMMM yyyy")</div>
                @if (!string.IsNullOrEmpty(Model.Bio))
                {
                    <div class="up-bio">@Model.Bio</div>
                }
            </div>
        </div>
    </div>

    <div class="up-content">

        <div class="up-section-title">Reading <span>Stats</span></div>
        <div class="up-stats-row">
            <div class="up-stat">
                <div class="up-stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 14H8v-2h8v2zm0-4H8v-2h8v2zm0-4H8V6h8v2z"/></svg>
                </div>
                <div class="up-stat-num">@Model.ManhwasRead</div>
                <div class="up-stat-label">Manhwa Read</div>
            </div>
            <div class="up-stat">
                <div class="up-stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/></svg>
                </div>
                <div class="up-stat-num">@Model.ChaptersRead.ToString("N0")</div>
                <div class="up-stat-label">Chapters Read</div>
            </div>
            <div class="up-stat">
                <div class="up-stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 14.24L11 13V7h1.5v5.25l4.58 2.73-1.09 1.76z"/></svg>
                </div>
                <div class="up-stat-num">@Model.DaysRead</div>
                <div class="up-stat-label">Days Read</div>
            </div>
            <div class="up-stat">
                <div class="up-stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
                </div>
                <div class="up-stat-num">@Model.PlanToRead</div>
                <div class="up-stat-label">Plan to Read</div>
            </div>
            <div class="up-stat">
                <div class="up-stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                </div>
                <div class="up-stat-num">@Model.Dropped</div>
                <div class="up-stat-label">Dropped</div>
            </div>
            <div class="up-stat">
                <div class="up-stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18z"/></svg>
                </div>
                <div class="up-stat-num">@Model.ReviewCount</div>
                <div class="up-stat-label">Reviews</div>
            </div>
        </div>

        <div class="up-section-title">Community <span>Activity</span></div>
        <div class="up-activity-row">
            <div class="up-activity-card up-activity--up">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"/></svg>
                <div>
                    <div class="up-activity-num">@Model.UpvotesReceived</div>
                    <div class="up-activity-label">Upvotes Received</div>
                </div>
            </div>
            <div class="up-activity-card up-activity--down">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M15 3H6c-.83 0-1.54.5-1.84 1.22l-3.02 7.05c-.09.23-.14.47-.14.73v2c0 1.1.9 2 2 2h6.31l-.95 4.57-.03.32c0 .41.17.79.44 1.06L9.83 23l6.59-6.59c.36-.36.58-.86.58-1.41V5c0-1.1-.9-2-2-2zm4 0v12h4V3h-4z"/></svg>
                <div>
                    <div class="up-activity-num">@Model.DownvotesReceived</div>
                    <div class="up-activity-label">Downvotes Received</div>
                </div>
            </div>
        </div>

        @if (Model.RecentReviews.Any())
        {
            <div class="up-section-title" style="margin-top:36px">Recent <span>Reviews</span></div>
            <div class="up-reviews">
                @foreach (var review in Model.RecentReviews)
                {
                    <div class="up-review-card">
                        <div class="up-review-header">
                            <div class="up-review-score">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:3px;margin-bottom:2px"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                @review.Score / 10
                            </div>
                            <div class="up-review-date">@review.CreatedAt.ToString("MMM d, yyyy")</div>
                        </div>
                        <div class="up-review-text">@review.Comment</div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="up-no-reviews" style="margin-top:36px">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor" opacity="0.25"><path d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18z"/></svg>
                <span>No reviews yet.</span>
            </div>
        }

    </div>
</div>
