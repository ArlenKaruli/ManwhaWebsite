@model ManwhaWebsite.Models.MangaDetailViewModel
@using ManwhaWebsite.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@{
    Layout = "~/Views/Shared/_VaultLayout.cshtml";
    ViewData["Title"] = Model.Title;
    var bgUrl = Model.BannerImageUrl ?? Model.CoverImageUrl;
    var isSignedIn = SignInManager.IsSignedIn(User);
    var currentStatus = Model.CurrentUserReadingStatus;
}

@section Styles {
    <link rel="stylesheet" href="~/css/manga-detail.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reading-list.css" asp-append-version="true" />
}

<!-- BANNER -->
<div class="manga-banner">
    <div class="manga-banner-bg" style="background-image:url('@bgUrl')"></div>
    <div class="manga-banner-overlay"></div>
</div>

<!-- BODY -->
<div class="manga-body">

    <!-- SIDEBAR -->
    <aside class="manga-sidebar">
        <div class="manga-cover">
            <img src="@Model.CoverImageUrl" alt="@Model.Title" />
        </div>
        <div class="manga-sidebar-right">
            <div class="manga-score-box">
                @if (Model.Score > 0)
                {
                    <div class="score-community">
                        <span class="manga-score-num">@Model.Score.ToString("F1")</span>
                        <span class="manga-score-label">Community Score</span>
                    </div>
                    <div class="score-box-divider"></div>
                }
                <div class="score-user">
                    <span class="score-user-label">Your Score</span>
                    @if (isSignedIn)
                    {
                        <form method="post" action="/manga/@Model.AniListId/rate" id="ratingForm">
                            @Html.AntiForgeryToken()
                            <select name="score" class="rating-select">
                                @if (!Model.CurrentUserRating.HasValue)
                                {
                                    <option value="0" selected>— Select —</option>
                                }
                                else
                                {
                                    <option value="0">— Select —</option>
                                }
                                @for (int i = 1; i <= 10; i++)
                                {
                                    if (Model.CurrentUserRating == i)
                                    {
                                        <option value="@i" selected>@i / 10</option>
                                    }
                                    else
                                    {
                                        <option value="@i">@i / 10</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="rp-save">Save Rating</button>
                        </form>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login" class="score-user-signin">Sign in to rate</a>
                    }
                </div>
            </div>
            <div class="manga-stat-table">
                @if (Model.ScoreRank > 0)
                {
                    <div class="manga-stat-row">
                        <span class="manga-stat-label">Ranked</span>
                        <span class="manga-stat-value accent">#@Model.ScoreRank</span>
                    </div>
                }
                @if (Model.PopularityRank > 0)
                {
                    <div class="manga-stat-row">
                        <span class="manga-stat-label">Popularity</span>
                        <span class="manga-stat-value accent">#@Model.PopularityRank</span>
                    </div>
                }
                <div class="manga-stat-row">
                    <span class="manga-stat-label">Readers</span>
                    <span class="manga-stat-value">@FormatNum(Model.Popularity)</span>
                </div>
                @if (Model.Favourites > 0)
                {
                    <div class="manga-stat-row">
                        <span class="manga-stat-label">Favorites</span>
                        <span class="manga-stat-value gold">@FormatNum(Model.Favourites)</span>
                    </div>
                }
                <div class="manga-stat-row">
                    <span class="manga-stat-label">Status</span>
                    <span class="manga-stat-value">@FormatStatus(Model.Status)</span>
                </div>
                <div class="manga-stat-row">
                    <span class="manga-stat-label">Chapters</span>
                    <span class="manga-stat-value">@(Model.Chapters.HasValue ? Model.Chapters.ToString() : "?")</span>
                </div>
                @if (Model.Volumes.HasValue)
                {
                    <div class="manga-stat-row">
                        <span class="manga-stat-label">Volumes</span>
                        <span class="manga-stat-value">@Model.Volumes</span>
                    </div>
                }
                @if (Model.StartYear.HasValue)
                {
                    <div class="manga-stat-row">
                        <span class="manga-stat-label">Year</span>
                        <span class="manga-stat-value">@Model.StartYear</span>
                    </div>
                }
            </div>

        </div>
    </aside>

    <!-- MAIN -->
    <main class="manga-main">

        <div class="manga-breadcrumb">
            <a href="/">Home</a>
            <span>/</span>
            <span>@Model.Title</span>
        </div>

        <!-- Title -->
        <h1 class="manga-title">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.AlternativeTitle))
        {
            <div class="manga-alt-title">@Model.AlternativeTitle</div>
        }

        <!-- Genres -->
        @if (Model.Genres.Any())
        {
            <div class="manga-genres">
                @foreach (var genre in Model.Genres)
                {
                    <span class="genre-pill">@genre</span>
                }
            </div>
        }

        <!-- ADD TO LIST -->
        @{
            string StatusLabel(ReadingStatus s) => s switch
            {
                ReadingStatus.Reading    => "Reading",
                ReadingStatus.Completed  => "Completed",
                ReadingStatus.PlanToRead => "Plan to Read",
                ReadingStatus.Dropped    => "Dropped",
                _                        => ""
            };
            string StatusIcon(ReadingStatus s) => s switch
            {
                ReadingStatus.Reading    => "📖",
                ReadingStatus.Completed  => "✓",
                ReadingStatus.PlanToRead => "🔖",
                ReadingStatus.Dropped    => "✕",
                _                        => ""
            };
            var btnLabel = currentStatus.HasValue ? StatusLabel(currentStatus.Value) : "Add to List";
        }
        @if (isSignedIn)
        {
            <div class="atl-dropdown" id="atlDropdown">
                <button class="atl-trigger @(currentStatus.HasValue ? "atl-trigger--active" : "")" onclick="toggleAtl(event)" type="button">
                    @if (currentStatus.HasValue)
                    {
                        <span class="atl-trigger-icon">@StatusIcon(currentStatus.Value)</span>
                    }
                    else
                    {
                        <svg class="atl-plus" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                    }
                    @btnLabel
                    <svg class="atl-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7 10l5 5 5-5z"/></svg>
                </button>
                <div class="atl-menu" id="atlMenu" role="menu">
                    <form method="post" action="/ReadingList/Add">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="aniListId" value="@Model.AniListId" />
                        <input type="hidden" name="title" value="@Model.Title" />
                        <input type="hidden" name="coverImageUrl" value="@Model.CoverImageUrl" />
                        @if (Model.Chapters.HasValue) { <input type="hidden" name="chapters" value="@Model.Chapters" /> }
                        <input type="hidden" name="returnUrl" value="/manga/@Model.AniListId" />
                        <button type="submit" name="status" value="0" class="atl-option @(currentStatus == ReadingStatus.Reading ? "atl-option--active" : "")" role="menuitem">
                            <span class="atl-option-dot atl-dot-reading"></span>Reading
                            @if (currentStatus == ReadingStatus.Reading) { <span class="atl-check">✓</span> }
                        </button>
                        @if (Model.Chapters.HasValue)
                        {
                        <button type="submit" name="status" value="1" class="atl-option @(currentStatus == ReadingStatus.Completed ? "atl-option--active" : "")" role="menuitem">
                            <span class="atl-option-dot atl-dot-completed"></span>Completed
                            @if (currentStatus == ReadingStatus.Completed) { <span class="atl-check">✓</span> }
                        </button>
                        }
                        <button type="submit" name="status" value="2" class="atl-option @(currentStatus == ReadingStatus.PlanToRead ? "atl-option--active" : "")" role="menuitem">
                            <span class="atl-option-dot atl-dot-plantoread"></span>Plan to Read
                            @if (currentStatus == ReadingStatus.PlanToRead) { <span class="atl-check">✓</span> }
                        </button>
                        <button type="submit" name="status" value="3" class="atl-option @(currentStatus == ReadingStatus.Dropped ? "atl-option--active" : "")" role="menuitem">
                            <span class="atl-option-dot atl-dot-dropped"></span>Dropped
                            @if (currentStatus == ReadingStatus.Dropped) { <span class="atl-check">✓</span> }
                        </button>
                    </form>
                    @if (currentStatus.HasValue)
                    {
                        <div class="atl-menu-divider"></div>
                        <form method="post" action="/ReadingList/Remove">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="aniListId" value="@Model.AniListId" />
                            <input type="hidden" name="returnUrl" value="/manga/@Model.AniListId" />
                            <button type="submit" class="atl-option atl-option--remove" role="menuitem">Remove from list</button>
                        </form>
                    }
                </div>
            </div>
        }
        else
        {
            <a href="/Identity/Account/Login" class="atl-trigger atl-trigger--guest">
                <svg class="atl-plus" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                Add to List
            </a>
        }

        <!-- Synopsis -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div>
                <div class="manga-section-title">Synopsis</div>
                <p class="manga-synopsis">@Model.Description</p>
            </div>
        }

        <!-- Characters -->
        @if (Model.Characters.Any())
        {
            <div>
                <div class="manga-section-title">Characters</div>
                <div class="characters-grid">
                    @foreach (var character in Model.Characters)
                    {
                        <div class="character-card">
                            <div class="character-img">
                                @if (!string.IsNullOrEmpty(character.ImageUrl))
                                {
                                    <img src="@character.ImageUrl" alt="@character.Name" loading="lazy" />
                                }
                            </div>
                            <div class="character-name">@character.Name</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Reviews -->
        <div class="reviews-section">
            <div class="manga-section-title">Community Reviews</div>

            @if (!Model.Reviews.Any())
            {
                <div class="no-reviews">No reviews yet. Be the first to write one!</div>
            }
            else
            {
                foreach (var review in Model.Reviews)
                {
                    <div class="review-card">
                        <div class="review-header">
                            <div class="review-avatar">
                                @if (!string.IsNullOrEmpty(review.UserProfilePicture))
                                {
                                    <img src="@review.UserProfilePicture" alt="@review.UserDisplayName" />
                                }
                                else
                                {
                                    <span class="review-avatar-placeholder">&#9679;</span>
                                }
                            </div>
                            <div class="review-meta">
                                <div class="review-username">@review.UserDisplayName</div>
                                <div class="review-date">@review.CreatedAt.ToString("MMM dd, yyyy")</div>
                            </div>
                            <div class="review-score">@review.Score / 10</div>
                        </div>
                        <div class="review-body">@review.Comment</div>
                    </div>
                }
            }

            <!-- Write Review -->
            @if (isSignedIn)
            {
                <div class="review-form-section">
                    <div class="review-form-title">Write a Review</div>
                    <form method="post" action="/manga/@Model.AniListId/review" id="reviewForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="score" id="reviewScoreInput" value="5" />
                        <div class="review-score-row">
                            <span class="review-score-label">Score:</span>
                            @for (int i = 1; i <= 10; i++)
                            {
                                <button type="button"
                                        class="rating-btn @(i == 5 ? "selected" : "")"
                                        data-review-score="@i"
                                        onclick="selectReviewScore(@i)">@i</button>
                            }
                        </div>
                        <textarea name="comment"
                                  class="review-textarea"
                                  placeholder="Share your thoughts about this manhwa... (minimum 10 characters)"
                                  maxlength="2000"
                                  required></textarea>
                        <button type="submit" class="review-submit">Post Review</button>
                    </form>
                </div>
            }
            else
            {
                <div style="text-align:center;padding:24px;color:var(--text-muted);font-size:14px;">
                    <a href="/Identity/Account/Login" style="color:var(--accent);font-weight:600;">Sign in</a> to write a review.
                </div>
            }
        </div>

    </main>
</div>

@section Scripts {
<script>
    function selectReviewScore(score) {
        document.getElementById('reviewScoreInput').value = score;
        document.querySelectorAll('[data-review-score]').forEach(btn => {
            btn.classList.toggle('selected', parseInt(btn.dataset.reviewScore) === score);
        });
    }
    function toggleAtl(e) {
        e.stopPropagation();
        const dd = document.getElementById('atlDropdown');
        dd.classList.toggle('open');
    }
    document.addEventListener('click', function (e) {
        const dd = document.getElementById('atlDropdown');
        if (dd && !dd.contains(e.target)) dd.classList.remove('open');
    });
</script>
}

@functions {
    string FormatNum(int n)
    {
        if (n >= 1_000_000) return $"{n / 1_000_000.0:F1}M";
        if (n >= 1_000) return $"{n / 1_000.0:F0}K";
        return n.ToString();
    }

    string FormatStatus(string status) => status switch
    {
        "FINISHED" => "Completed",
        "RELEASING" => "Ongoing",
        "NOT_YET_RELEASED" => "Upcoming",
        "CANCELLED" => "Cancelled",
        "HIATUS" => "On Hiatus",
        _ => status,
    };
}
